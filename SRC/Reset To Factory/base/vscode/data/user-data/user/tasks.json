                        }
                    ]
                }
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true,
                "revealProblems": "onProblem"
            }
        },
        {
            "label": "Open ASM [Shift+F7]",
            "type": "shell",
            "command": "${execPath}",
            "args": [
                "-r",
                "'${fileDirname}\\${fileBasenameNoExtension}.ASM'"
            ],
            "presentation": {
                "echo": true,
                "reveal": "never",
                "focus": false,
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Open S",
            "type": "shell",
            "command": "${execPath}",
            "args": [
                "-r",
                "'${fileDirname}\\${fileBasenameNoExtension}.S'"
            ],
            "presentation": {
                "clear": true,
                "reveal": "silent",
                "close": true
            }
        },
        {
            "label": "Flash Previous",
