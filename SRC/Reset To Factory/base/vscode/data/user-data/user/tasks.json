{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Make HEX and Flash [F5]",
            "type": "shell",
            "command": "${env:GCBASIC_INSTALL_PATH}\\G+Stools\\useini.bat",
            "args": [
                "\"${file}\""
            ],
            "options": {
                "cwd": "${env:GCBASIC_INSTALL_PATH}\\GreatCowBasic\\"
            },
            "problemMatcher": [
                {
                    "owner": "gcb",
                    "source": "gcb",
                    "fileLocation": [
                        "relative",
                        "${fileDirname}"
                    ],
                    "pattern": [
                        {
                            "severity": 3,
                            "file": 1,
                            "line": 2,
                            "message": 4,
                            "regexp": "^(.*)\\s+\\((\\d+)\\):\\s+(Warning|Error):\\s+(.+)$"
                        }
                    ]
                }
            ],
            "group": "build",
            "presentation": {
                "clear": true,
                "revealProblems": "onProblem"
            }
        },
        {
            "label": "Make HEX [F6]",
            "type": "shell",
            "command": "${env:GCBASIC_INSTALL_PATH}\\G+Stools\\makehex.bat",
            "args": [
                "\"${file}\""
            ],
            "options": {
                "cwd": "${env:GCBASIC_INSTALL_PATH}\\GreatCowBasic\\"
            },
            "problemMatcher": [
                {
                    "owner": "gcb",
                    "source": "gcb",
                    "fileLocation": [
                        "relative",
                        "${fileDirname}"
                    ],
                    "pattern": [
                        {
                            "severity": 3,
                            "file": 1,
                            "line": 2,
                            "message": 4,
                            "regexp": "^(.*)\\s+\\((\\d+)\\):\\s+(Warning|Error):\\s+(.+)$"
                        }
                    ]
                }
            ],
            "group": "build",
            "presentation": {
                "clear": true,
                "revealProblems": "onProblem"
            }
        },
        {
            "label": "Make ASM [F7]",
            "type": "shell",
            "command": "${env:GCBASIC_INSTALL_PATH}\\G+Stools\\makeasm.bat",
            "args": [
                "\"${file}\""
            ],
            "options": {
                "cwd": "${env:GCBASIC_INSTALL_PATH}\\GreatCowBasic\\"
            },
            "problemMatcher": [
                {
                    "owner": "gcb",
                    "source": "gcb",
                    "fileLocation": [
                        "relative",
                        "${fileDirname}"
                    ],
